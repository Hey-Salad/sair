# ─── Alibaba Cloud Model Studio (Qwen) ────────────────────────────────────────
# Create a key at https://bailian.console.aliyun.com/  (Model Studio / DashScope)
# This is the ONLY credential needed for the EdgeAgent cloud-reasoning path.
DASHSCOPE_API_KEY=sk-your-alibaba-cloud-model-studio-key

# International endpoint (default). For Beijing/mainland use:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen models on Alibaba Cloud (override if you have access to others)
QWEN_VISION_MODEL=qwen-vl-max
QWEN_TEXT_MODEL=qwen-plus

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
